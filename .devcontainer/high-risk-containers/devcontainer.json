{
    "name": "Drasi Server - High Risk Containers Tutorial",
    // Ubuntu 24.04 (glibc 2.39). The source/kubernetes and bootstrap/kubernetes
    // plugins are built against glibc 2.39, so the older Debian bookworm base
    // (glibc 2.36) fails to load them with "GLIBC_2.39 not found".
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04@sha256:d94c97dd9cacf183d0a6fd12a8e87b526e9e928307674ae9c94139139c0c6eae",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "29",
            "moby": false
        },
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true,
            "configureZshAsDefaultShell": true
        },
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
            "minikube": "none"
        }
    },
    "postCreateCommand": "bash ../../.devcontainer/high-risk-containers/post-create.sh",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}/tutorials/high-risk-containers",
    "runArgs": [
        "--privileged",
        "--init",
        "--ipc=host"
    ],
    "forwardPorts": [
        8380,
        3000,
        5732
    ],
    "portsAttributes": {
        "8380": {
            "label": "Drasi Server API",
            "onAutoForward": "notify"
        },
        "3000": {
            "label": "High Risk Containers Dashboard",
            "onAutoForward": "notify"
        },
        "5732": {
            "label": "PostgreSQL",
            "onAutoForward": "silent"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "humao.rest-client"
            ],
            "settings": {
                "editor.formatOnSave": true
            }
        }
    },
    "remoteUser": "vscode",
    "remoteEnv": {
        "LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}"
    },
    "containerEnv": {
        "POSTGRES_HOST": "localhost",
        "POSTGRES_PORT": "5732",
        "POSTGRES_HOST_PORT": "5732",
        "SERVER_PORT": "8380",
        "DASHBOARD_PORT": "3000"
    }
}
