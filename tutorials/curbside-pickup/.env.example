# Example environment variables for the curbside-pickup tutorial
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env with real credentials!

# Retail Operations - PostgreSQL (orders)
POSTGRES_HOST=localhost
POSTGRES_PORT=5742
POSTGRES_HOST_PORT=5742
POSTGRES_DATABASE=RetailOperations
POSTGRES_USER=drasi_user
POSTGRES_PASSWORD=drasi_password

# Physical Operations - Microsoft SQL Server (vehicles)
MSSQL_HOST=localhost
MSSQL_PORT=1435
MSSQL_HOST_PORT=1435
MSSQL_DATABASE=PhysicalOperations
MSSQL_USER=drasi_user
MSSQL_PASSWORD=Drasi_Passw0rd!
# The SA password is used by the setup scripts to create the database and enable
# CDC. It must satisfy SQL Server's strong-password policy.
MSSQL_SA_PASSWORD=Drasi_Passw0rd!

# Drasi Server settings.
SERVER_HOST=0.0.0.0
SERVER_PORT=8480
LOG_LEVEL=info

# Dashboard reaction settings.
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=3000
