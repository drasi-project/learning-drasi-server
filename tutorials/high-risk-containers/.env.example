# Example environment variables for the high-risk-containers tutorial
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env with real credentials!

# PostgreSQL connection settings.
POSTGRES_HOST=localhost
POSTGRES_PORT=5732
POSTGRES_HOST_PORT=5732
POSTGRES_DATABASE=high_risk_containers
POSTGRES_USER=drasi_user
POSTGRES_PASSWORD=drasi_password

# Kubernetes (k3d) settings.
K3D_CLUSTER_NAME=high-risk-containers
K3D_API_PORT=6550
# Optional override for the kubectl helper scripts (upgrade-pod, reset). The
# server itself reads the kubeconfig path from server-config.yaml (bin/kubeconfig.yaml).
# KUBECONFIG_PATH=bin/kubeconfig.yaml

# Drasi Server settings.
SERVER_HOST=0.0.0.0
SERVER_PORT=8380
LOG_LEVEL=info

# Dashboard reaction settings.
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=3000

# Optional: Discord HTTP reaction (see the "Optional: Discord Alerts" step).
# The bash start-server.sh auto-loads this from .env; for PowerShell, set
# $env:DISCORD_WEBHOOK_URL before running start-server.ps1.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/<id>/<token>
