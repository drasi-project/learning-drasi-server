# Example environment variables for the building-comfort tutorial
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env with real credentials!

# PostgreSQL connection settings.
POSTGRES_HOST=localhost
POSTGRES_PORT=5732
POSTGRES_HOST_PORT=5732
POSTGRES_DATABASE=building_comfort
POSTGRES_USER=drasi_user
POSTGRES_PASSWORD=drasi_password

# Drasi Server settings.
SERVER_HOST=0.0.0.0
SERVER_PORT=8380
LOG_LEVEL=info

# Dashboard reaction settings.
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=3000
